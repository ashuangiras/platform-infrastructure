# Secrets and local configuration — required patterns for SEC-001 CI check
*.pem
*.key
*.p12
*.pfx
.env
.env.*
*.tfvars
*.tfvars.json

# Terraform working directories and generated files
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
*.tfplan
crash.log

# State at rest (P0-5) — belt-and-suspenders globs. State contains secrets.
*.tfstate
*.tfstate.*

# TLS material (P0-1) — certs are generated locally, never committed.
# (Private keys are already covered by *.key / *.pem above.)
*.crt
*.csr

# Local module overrides (staging validation) — redirect module `source` to the
# local platform-modules checkout. Gitignored so the committed tree keeps ?ref=v1.6.0.
*_override.tf

# State migration backend config — never commit this
backend.hcl
backend-minio.hcl

# OS / IDE
.DS_Store
.idea/
*.swp
terraform.tfstate.staging
terraform.tfstate.staging.backup
tfplan
*.bak

# Vault init keys — contains plaintext unseal keys and root token
# The actual file lives outside the repo per vault_keys_path, but guard against accidents
vault-keys*.json
*vault-keys*
