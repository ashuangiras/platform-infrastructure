# Secrets and local configuration — required patterns for SEC-001 CI check
*.pem
*.key
*.p12
*.pfx
.env
.env.*
*.tfvars
*.tfvars.json

# Terraform working directories and generated files
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
*.tfplan
crash.log

# State migration backend config — never commit this
backend.hcl
backend-minio.hcl

# OS / IDE
.DS_Store
.idea/
*.swp
