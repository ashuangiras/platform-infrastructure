# vault.hcl.example
#
# Copy this file to /srv/platform/vault/config/vault.hcl on the target host.
# The config_path variable in terraform.tfvars must point to the directory
# containing this file (renamed to vault.hcl, not vault.hcl.example).
#
# This file is NOT managed by Terraform — it is mounted read-only into the
# Vault container. Edit it manually and restart the container to apply changes.

storage "file" {
  # Mapped from var.vault_data_path (default: /srv/platform/vault/data)
  path = "/vault/data"
}

listener "tcp" {
  address     = "0.0.0.0:8200"
  # TLS is disabled for local dev. Enable TLS for production by providing
  # tls_cert_file and tls_key_file and removing tls_disable.
  tls_disable = true
}

# Allow the UI to be accessed at http://localhost:8200/ui
ui = true

# Required for Vault clustering and OIDC redirect URIs
api_addr     = "http://0.0.0.0:8200"
cluster_addr = "http://0.0.0.0:8201"
