# vault.hcl.example
#
# Copy this file to /srv/platform/vault/config/vault.hcl on the target host.
# The config_path variable in terraform.tfvars must point to the directory
# containing this file (renamed to vault.hcl, not vault.hcl.example).
#
# ⚠ CONTRACT CHANGE (P0-1): vault.hcl is now TERRAFORM-MANAGED.
# Terraform writes ${vault_config_path}/vault.hcl on every apply via
# local_file.vault_config in secrets/main.tf. The content is selected by
# var.tls_enabled — DO NOT hand-edit the deployed vault.hcl anymore; flip
# tls_enabled and re-apply instead. This file is kept only as documentation
# of what Terraform writes (and as a manual fallback if you disable the
# local_file resource).
#
# The listener certs are bind-mounted by the vault module at /vault/tls/.

storage "file" {
  # Mapped from var.vault_data_path (default: /srv/platform/vault/data)
  path = "/vault/data"
}

# ── TLS listener (tls_enabled = true) ────────────────────────────────────────
listener "tcp" {
  address       = "0.0.0.0:8200"
  tls_disable   = false
  tls_cert_file = "/vault/tls/tls.crt"
  tls_key_file  = "/vault/tls/tls.key"
}

# Allow the UI to be accessed at https://localhost:8200/ui
ui = true

# Required for Vault clustering and OIDC redirect URIs (https when TLS is on)
api_addr     = "https://127.0.0.1:8200"
cluster_addr = "https://127.0.0.1:8201"

# ── PLAINTEXT FALLBACK (rollback: tls_enabled = false) ───────────────────────
# Terraform writes the following automatically when var.tls_enabled = false,
# restoring the previous plaintext behavior exactly:
#
# listener "tcp" {
#   address     = "0.0.0.0:8200"
#   tls_disable = true
# }
#
# api_addr     = "http://0.0.0.0:8200"
# cluster_addr = "http://0.0.0.0:8201"
